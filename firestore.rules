rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all safety net: deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Validate ID strings to prevent junk data / resource exhaustion
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- USER PROFILE RULES ---
    match /users/{userId} {
      allow get: if isValidId(userId);
      allow list: if true; // allow query listing (will be filtered by client-side queries)
      allow create: if isValidId(userId) && isValidUserProfile(request.resource.data);
      allow update: if isValidId(userId) && isValidUserProfile(request.resource.data)
                    && request.resource.data.uid == resource.data.uid;
      allow delete: if false; // profiles cannot be deleted by users
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'name'])
        && data.keys().size() >= 3
        && data.keys().size() <= 7
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 128
        && data.name is string && data.name.size() <= 128
        && (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 64))
        && (!data.keys().hasAny(['telegram']) || (data.telegram is string && data.telegram.size() <= 64))
        && (!data.keys().hasAny(['currentVisa']) || (data.currentVisa is string && data.currentVisa.size() <= 200))
        && (!data.keys().hasAny(['referredBy']) || (data.referredBy is string && data.referredBy.size() <= 128));
    }

    // --- BOOKING RULES ---
    match /bookings/{bookingId} {
      allow get: if isValidId(bookingId);
      allow list: if true;
      allow create: if isValidBooking(request.resource.data);
      allow update: if isValidBooking(request.resource.data)
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'serviceId', 'serviceTitle', 'date', 'timeSlot', 'status'])
        && data.keys().size() >= 6
        && data.keys().size() <= 12
        && data.userId is string && data.userId.size() <= 128
        && data.serviceId is string && data.serviceId.size() <= 128
        && data.serviceTitle is string && data.serviceTitle.size() <= 200
        && data.date is string && data.date.size() <= 64
        && data.timeSlot is string && data.timeSlot.size() <= 64
        && data.status is string && data.status.size() <= 64
        && (!data.keys().hasAny(['userEmail']) || (data.userEmail is string && data.userEmail.size() <= 128))
        && (!data.keys().hasAny(['userName']) || (data.userName is string && data.userName.size() <= 128))
        && (!data.keys().hasAny(['userPhone']) || (data.userPhone is string && data.userPhone.size() <= 64))
        && (!data.keys().hasAny(['userTelegram']) || (data.userTelegram is string && data.userTelegram.size() <= 64))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 128));
    }

    // --- CHAT MESSAGE RULES ---
    match /chat_messages/{messageId} {
      allow get: if isValidId(messageId);
      allow list: if true;
      allow create: if isValidChatMessage(request.resource.data);
      allow update: if false; // messages are immutable once sent
      allow delete: if false;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'sender', 'text', 'timestamp'])
        && data.keys().size() >= 4
        && data.keys().size() <= 6
        && data.userId is string && data.userId.size() <= 128
        && data.sender is string && data.sender.size() <= 64
        && data.text is string && data.text.size() <= 5000
        && data.timestamp is string && data.timestamp.size() <= 128;
    }

    // --- NOTIFICATION RULES ---
    match /notifications/{notificationId} {
      allow get: if isValidId(notificationId);
      allow list: if true;
      allow create: if isValidNotification(request.resource.data);
      allow update: if isValidNotification(request.resource.data)
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt'])
        && data.keys().size() >= 6
        && data.keys().size() <= 8
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 500
        && data.message is string && data.message.size() <= 2000
        && data.type is string && data.type.size() <= 64
        && data.read is bool
        && data.createdAt is string && data.createdAt.size() <= 128
        && (!data.keys().hasAny(['bookingId']) || (data.bookingId is string && data.bookingId.size() <= 128));
    }

    // --- DOCUMENT RULES ---
    match /documents/{documentId} {
      allow get: if isValidId(documentId);
      allow list: if true;
      allow create: if isValidDocument(request.resource.data);
      allow update: if isValidDocument(request.resource.data)
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['userId', 'id', 'name', 'status', 'lastUpdated'])
        && data.keys().size() >= 5
        && data.keys().size() <= 9
        && data.userId is string && data.userId.size() <= 128
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 500
        && data.status is string && data.status.size() <= 64
        && data.lastUpdated is string && data.lastUpdated.size() <= 200
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 2000))
        && (!data.keys().hasAny(['fileData']) || (data.fileData is string && data.fileData.size() <= 2000000))
        && (!data.keys().hasAny(['fileName']) || (data.fileName is string && data.fileName.size() <= 256))
        && (!data.keys().hasAny(['fileSize']) || (data.fileSize is string && data.fileSize.size() <= 64));
    }
  }
}
